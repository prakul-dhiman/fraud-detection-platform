# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environment
venv/
env/
.venv/
.env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoint

# Model files (large binary files — committed separately)
*.pkl
*.joblib
*.h5

# Dataset (too large for git — download from Kaggle)
creditcard.csv
*.csv

# Environment variables — NEVER commit these!
.env
.env.local
.env.production

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*
dist/
build/

# Docker
.dockerignore

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/settings.json
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Test coverage
coverage/
.coverage
htmlcov/
